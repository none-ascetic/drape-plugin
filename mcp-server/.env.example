# Wholesale Platform Credentials
# Currently supports: NuOrder
# Run /drape:setup to configure automatically.

# NuOrder OAuth 1.0 credentials
# Obtain from: NuOrder account → Settings → API → OAuth Credentials
NUORDER_CONSUMER_KEY=
NUORDER_CONSUMER_SECRET=
NUORDER_TOKEN=
NUORDER_TOKEN_SECRET=

# NuOrder domain (default: wholesale.nuorder.com)
NUORDER_DOMAIN=wholesale.nuorder.com

# Set to true to prevent any write operations (recommended for initial setup)
NUORDER_READ_ONLY=true

# Optional: Apiary mock/proxy domains for testing (provided by NuOrder support)
# NUORDER_MOCK_DOMAIN=your-mock-domain.apiary-mock.com
# NUORDER_PROXY_DOMAIN=your-proxy-domain.apiary-proxy.com
