# NuOrder OAuth 1.0 credentials
# Obtain from NuOrder API settings or NuOrder support
NUORDER_CONSUMER_KEY=your_consumer_key_here
NUORDER_CONSUMER_SECRET=your_consumer_secret_here
NUORDER_TOKEN=your_oauth_token_here
NUORDER_TOKEN_SECRET=your_oauth_token_secret_here

# NuOrder API domain (default: wholesale.nuorder.com)
NUORDER_DOMAIN=wholesale.nuorder.com

# Optional: override with NuOrder-provided Apiary mock/proxy domains for testing
# NUORDER_MOCK_DOMAIN=your-mock-domain.apiary-mock.com
# NUORDER_PROXY_DOMAIN=your-proxy-domain.apiary-proxy.com

# Set to "true" to disable all write operations (create/update/delete)
# Recommended when testing against production data
NUORDER_READ_ONLY=false
